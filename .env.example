ENVIRONMENT=development

DATABASE_URL=sqlite:///./tossline.db
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
PIN_EXPIRE_MINUTES=10

# Email backend: "console" (prints PIN to server logs) or "resend" (the
# code default). Set to "console" here for local dev so you don't need a
# real Resend key to test the login flow.
EMAIL_BACKEND=console
RESEND_API_KEY=
EMAIL_FROM=login@evervolley.com

# Scout assistant (OpenAI). OPEN_AI_KEY matches the name already set on Railway.
# OPENAI_MODEL is optional; a small model like gpt-4o-mini is plenty for
# turning a coach's request into a scout filter.
OPEN_AI_KEY=
OPENAI_MODEL=gpt-4o-mini

# /admin/db is only reachable when logged in (via email-PIN) as this address.
ADMIN_EMAIL=federico.cian@gmail.com
