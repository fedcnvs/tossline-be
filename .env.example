ENVIRONMENT=development

DATABASE_URL=sqlite:///./tossline.db
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
PIN_EXPIRE_MINUTES=10

# Email backend: "console" (prints PIN to server logs) or "resend"
EMAIL_BACKEND=console
RESEND_API_KEY=
EMAIL_FROM=login@tossline.example

# Leave both blank to disable /admin/db entirely (returns 404).
ADMIN_USERNAME=
ADMIN_PASSWORD=
