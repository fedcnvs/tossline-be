ENVIRONMENT=development

DATABASE_URL=sqlite:///./tossline.db
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
PIN_EXPIRE_MINUTES=10

# Email backend: "console" (prints PIN to server logs) or "resend"
EMAIL_BACKEND=console
RESEND_API_KEY=
EMAIL_FROM=login@tossline.example

# /admin/db is only reachable when logged in (via email-PIN) as this address.
ADMIN_EMAIL=federico.cian@gmail.com
